# ================================================================
# AMB2API 环境变量配置示例文件
# 复制此文件为 .env 并根据需要修改配置值
# ================================================================

# 服务器监听地址
# 默认: 0.0.0.0 (监听所有网络接口)
HOST=0.0.0.0
# 服务器端口
PORT=7861

# 聊天API访问密码 (用于OpenAI和Gemini API端点认证)
API_PASSWORD=your_api_password
# 控制面板访问密码 (用于Web界面登录认证)
PANEL_PASSWORD=your_panel_password
# 通用访问密码
# 设置后会覆盖上述两个专用密码，优先级最高；如果只想使用一个密码，设置此项即可
PASSWORD=pwd

# 使用 AssemblyAI 作为上游（默认: true）
USE_ASSEMBLY=true
ASSEMBLY_ENDPOINT=https://llm-gateway.assemblyai.com/v1/chat/completions
# AssemblyAI API Keys（多个用逗号分隔，或在面板配置）
ASSEMBLY_API_KEYS=

REDIS_URI=redis://:your_redis_password@your-redis-host:6379/0
REDIS_PREFIX=AMB2API

CALLS_PER_ROTATION=100
PROXY=
CONFIG_OVERRIDE_ENV=true

AUTO_BAN=false
AUTO_BAN_ERROR_CODES=401,403
RETRY_429_ENABLED=true
RETRY_429_MAX_RETRIES=5
RETRY_429_INTERVAL=1

LOG_LEVEL=info
LOG_FILE=log.txt
PLATFORM=linux/amd64
